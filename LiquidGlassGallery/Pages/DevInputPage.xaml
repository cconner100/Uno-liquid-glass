<Page x:Class="LiquidGlassGallery.Pages.DevInputPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:dev="using:DevWinUI.LiquidGlass">

  <ScrollViewer Padding="28,0">
    <StackPanel Spacing="16" HorizontalAlignment="Stretch" Padding="0,24,0,32">

      <TextBlock Text="Input" FontSize="30" FontWeight="Bold" Foreground="White" />

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="PinBox" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="PIN entry with one glass cell per character. Typing advances focus; backspace moves back."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <StackPanel Spacing="10" Margin="0,10,0,0">
            <dev:PinBox x:Name="HiddenPin" PasswordChanged="OnPinChanged" />
            <TextBlock x:Name="PinValueText" Text="Entered: (empty)"
                       FontSize="13" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
            <TextBlock Text="Six digits, visible characters:"
                       FontSize="13" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,6,0,0" />
            <dev:PinBox PasswordLength="6" IsPasswordVisible="True" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="KeyVisual" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="A single keyboard key cap, in three sizes."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <dev:KeyVisual Content="Esc" VisualType="Small" VerticalAlignment="Center" />
            <dev:KeyVisual Content="⌘" VerticalAlignment="Center" />
            <dev:KeyVisual Content="⇧" VerticalAlignment="Center" />
            <dev:KeyVisual Content="P" VerticalAlignment="Center" />
            <dev:KeyVisual Content="Enter" VisualType="Large" VerticalAlignment="Center" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="Shortcut" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="A key combination rendered as key caps joined by plus signs. Keys is a comma-separated list."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <StackPanel Spacing="10" Margin="0,10,0,0">
            <dev:Shortcut Keys="Cmd,Shift,P" />
            <dev:Shortcut Keys="Ctrl,Alt,Delete" />
            <dev:Shortcut Keys="⌘,C" VisualType="Large" />
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</Page>
