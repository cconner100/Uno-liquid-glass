<Page x:Class="LiquidGlassGallery.Pages.ToolkitLayoutsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls">

  <Page.Resources>
    <!--  Small glass tile used by every panel demo  -->
    <Style x:Key="GlassTileStyle" TargetType="Border">
      <Setter Property="Background" Value="{ThemeResource LiquidGlassFillBrush}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12,10" />
    </Style>
    <Style x:Key="GlassTileLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Page.Resources>

  <ScrollViewer Padding="28,0">
    <StackPanel Spacing="16" HorizontalAlignment="Stretch" Padding="0,24,0,32">

      <TextBlock Text="Layouts &amp; panels" FontSize="30" FontWeight="Bold" Foreground="White" />
      <TextBlock Text="Windows Community Toolkit layout primitives running on Uno Platform. Panels have no visuals of their own — the liquid glass lives in their children — while the sizers pick up glass grip and track resources from the theme."
                 FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />

      <!--  WrapPanel  -->
      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="WrapPanel" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Positions children sequentially and wraps to the next line when the row is full. Resize the window to see the chips reflow."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <controls:WrapPanel HorizontalSpacing="8" VerticalSpacing="8" Margin="0,10,0,0">
            <Border Style="{StaticResource GlassTileStyle}" Padding="14,8">
              <TextBlock Text="Wrap" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Style="{StaticResource GlassTileStyle}" Padding="14,8">
              <TextBlock Text="Liquid glass" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Style="{StaticResource GlassTileStyle}" Padding="14,8">
              <TextBlock Text="Chips" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Style="{StaticResource GlassTileStyle}" Padding="14,8">
              <TextBlock Text="Flowing left to right" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Style="{StaticResource GlassTileStyle}" Padding="14,8">
              <TextBlock Text="Uno" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Style="{StaticResource GlassTileStyle}" Padding="14,8">
              <TextBlock Text="Toolkit" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Style="{StaticResource GlassTileStyle}" Padding="14,8">
              <TextBlock Text="Variable width" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Style="{StaticResource GlassTileStyle}" Padding="14,8">
              <TextBlock Text="Then wraps" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
          </controls:WrapPanel>
        </StackPanel>
      </Border>

      <!--  DockPanel  -->
      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="DockPanel" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Docks children to the edges with the attached Dock property; the last child fills the remaining space."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <controls:DockPanel LastChildFill="True" Height="200" Margin="0,10,0,0">
            <Border controls:DockPanel.Dock="Top" Height="40" Margin="2" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="Top" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border controls:DockPanel.Dock="Bottom" Height="40" Margin="2" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="Bottom" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border controls:DockPanel.Dock="Left" Width="80" Margin="2" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="Left" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border controls:DockPanel.Dock="Right" Width="80" Margin="2" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="Right" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Margin="2" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="Fill" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
          </controls:DockPanel>
        </StackPanel>
      </Border>

      <!--  UniformGrid  -->
      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="UniformGrid" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="The toolkit's UniformGrid gives every child an equally sized cell — here locked to three columns."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <controls:UniformGrid Columns="3" ColumnSpacing="10" RowSpacing="10" Margin="0,10,0,0">
            <Border Height="64" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="1" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="64" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="2" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="64" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="3" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="64" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="4" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="64" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="5" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="64" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="6" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
          </controls:UniformGrid>
        </StackPanel>
      </Border>

      <!--  StaggeredPanel  -->
      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="StaggeredPanel" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="A masonry layout: children flow into columns of a desired width, each new item landing in the shortest column."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <controls:StaggeredPanel DesiredColumnWidth="120" ColumnSpacing="10" RowSpacing="10" Margin="0,10,0,0">
            <Border Height="64" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="A" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="120" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="B" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="88" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="C" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="140" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="D" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="72" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="E" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="104" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="F" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <Border Height="56" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="G" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
          </controls:StaggeredPanel>
        </StackPanel>
      </Border>

      <!--  ConstrainedBox  -->
      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="ConstrainedBox" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Constrains its content to an aspect ratio. The tile below always stays 16:9 — its height follows from whatever width the column gives it."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <controls:ConstrainedBox AspectRatio="16:9" MaxWidth="360" HorizontalAlignment="Left" Margin="0,10,0,0">
            <Border Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="16 : 9" FontSize="17" FontWeight="SemiBold" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
          </controls:ConstrainedBox>
          <TextBlock Text="AspectRatio=&quot;16:9&quot; with MaxWidth 360 — the box computes the height, not you."
                     FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassTertiaryLabelBrush}" />
        </StackPanel>
      </Border>

      <!--  SwitchPresenter  -->
      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="SwitchPresenter" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="A switch statement for XAML: shows the Case whose Value matches the bound value. Pick a mode to swap the card below."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <ComboBox x:Name="ModePicker" MinWidth="180" Margin="0,10,0,0" SelectedIndex="0">
            <x:String>Overview</x:String>
            <x:String>Details</x:String>
            <x:String>Activity</x:String>
          </ComboBox>
          <controls:SwitchPresenter Margin="0,10,0,0"
                                    TargetType="x:String"
                                    Value="{x:Bind ModePicker.SelectedItem, Mode=OneWay}">
            <controls:Case Value="Overview">
              <Border Style="{StaticResource GlassTileStyle}" Padding="16,14">
                <StackPanel Spacing="4">
                  <TextBlock Text="Overview" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
                  <TextBlock Text="The big picture at a glance — a summary card rendered only while this case matches."
                             FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
                </StackPanel>
              </Border>
            </controls:Case>
            <controls:Case Value="Details">
              <Border Style="{StaticResource GlassTileStyle}" Padding="16,14">
                <StackPanel Spacing="4">
                  <TextBlock Text="Details" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
                  <TextBlock Text="Field-by-field specifics. A completely different visual tree from the other cases."
                             FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
                </StackPanel>
              </Border>
            </controls:Case>
            <controls:Case Value="Activity">
              <Border Style="{StaticResource GlassTileStyle}" Padding="16,14">
                <StackPanel Spacing="4">
                  <TextBlock Text="Activity" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
                  <TextBlock Text="Recent events and history — swapped in the moment the ComboBox value becomes 'Activity'."
                             FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
                </StackPanel>
              </Border>
            </controls:Case>
          </controls:SwitchPresenter>
        </StackPanel>
      </Border>

      <!--  GridSplitter  -->
      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="GridSplitter" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Drag the glass grip to redistribute space between the two panes. The grip and track pick up liquid glass resources from the theme."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <Grid Height="160" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="80" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" MinWidth="80" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="Pane A" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
            <controls:GridSplitter Grid.Column="1"
                                   Width="12"
                                   Margin="4,0"
                                   CornerRadius="6"
                                   Background="{ThemeResource LiquidGlassClearFillBrush}"
                                   Foreground="{ThemeResource LiquidGlassSeparatorBrush}" />
            <Border Grid.Column="2" Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="Pane B" Style="{StaticResource GlassTileLabelStyle}" />
            </Border>
          </Grid>
        </StackPanel>
      </Border>

      <!--  Headered controls  -->
      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="Headered controls" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="HeaderedContentControl and HeaderedItemsControl pair arbitrary header content with a body or an item list — the header here is styled per instance."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />

          <controls:HeaderedContentControl Margin="0,10,0,0" HorizontalContentAlignment="Stretch">
            <controls:HeaderedContentControl.Header>
              <TextBlock Text="Now playing" FontSize="15" FontWeight="SemiBold"
                         Foreground="{ThemeResource LiquidGlassLabelBrush}" Margin="0,0,0,8" />
            </controls:HeaderedContentControl.Header>
            <Border Style="{StaticResource GlassTileStyle}" Padding="16,14" HorizontalAlignment="Stretch">
              <TextBlock Text="A single content region under a header — the simplest headered wrapper."
                         FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
            </Border>
          </controls:HeaderedContentControl>

          <controls:HeaderedItemsControl Margin="0,14,0,0">
            <controls:HeaderedItemsControl.Header>
              <TextBlock Text="Up next" FontSize="15" FontWeight="SemiBold"
                         Foreground="{ThemeResource LiquidGlassLabelBrush}" Margin="0,0,0,8" />
            </controls:HeaderedItemsControl.Header>
            <Border Style="{StaticResource GlassTileStyle}" Margin="0,0,0,6">
              <TextBlock Text="First item" FontSize="13" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
            </Border>
            <Border Style="{StaticResource GlassTileStyle}" Margin="0,0,0,6">
              <TextBlock Text="Second item" FontSize="13" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
            </Border>
            <Border Style="{StaticResource GlassTileStyle}">
              <TextBlock Text="Third item" FontSize="13" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
            </Border>
          </controls:HeaderedItemsControl>
        </StackPanel>
      </Border>

      <!--  LayoutTransformControl  -->
      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="LayoutTransformControl" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Applies a transform during layout, not just rendering — the surrounding layout reserves the rotated bounds instead of letting the card overlap its neighbors."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <controls:LayoutTransformControl Margin="0,14,0,4" HorizontalAlignment="Left">
            <controls:LayoutTransformControl.Transform>
              <RotateTransform Angle="-8" />
            </controls:LayoutTransformControl.Transform>
            <controls:LayoutTransformControl.Child>
              <Border Style="{StaticResource GlassTileStyle}" Width="260" Padding="18,14">
                <StackPanel Spacing="4">
                  <TextBlock Text="Rotated -8°" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
                  <TextBlock Text="This glass card takes up its rotated footprint in layout."
                             FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
                </StackPanel>
              </Border>
            </controls:LayoutTransformControl.Child>
          </controls:LayoutTransformControl>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</Page>
