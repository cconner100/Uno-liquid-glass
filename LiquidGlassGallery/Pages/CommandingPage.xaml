<Page x:Class="LiquidGlassGallery.Pages.CommandingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer Padding="28,0">
    <StackPanel Spacing="16" MaxWidth="780" HorizontalAlignment="Stretch" Padding="0,24,0,32">

      <TextBlock Text="Commanding" FontSize="30" FontWeight="Bold" Foreground="White" />

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="MenuBar" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="A chromeless bar of rounded text buttons; menus open on the glass surface with macOS-style tint highlights."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,0,0,10" />
          <MenuBar>
            <MenuBarItem Style="{StaticResource LiquidGlassMenuBarItemStyle}" Title="File">
              <MenuFlyoutItem Text="New" />
              <MenuFlyoutItem Text="Open…" />
              <MenuFlyoutSeparator />
              <MenuFlyoutSubItem Text="Open Recent">
                <MenuFlyoutItem Text="Quarterly Report.pages" />
                <MenuFlyoutItem Text="Moodboard.sketch" />
                <MenuFlyoutItem Text="Roadmap.numbers" />
              </MenuFlyoutSubItem>
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="Save" />
              <MenuFlyoutItem Text="Close" />
            </MenuBarItem>
            <MenuBarItem Style="{StaticResource LiquidGlassMenuBarItemStyle}" Title="Edit">
              <MenuFlyoutItem Text="Undo" />
              <MenuFlyoutItem Text="Redo" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="Cut" />
              <MenuFlyoutItem Text="Copy" />
              <MenuFlyoutItem Text="Paste" />
              <MenuFlyoutSeparator />
              <MenuFlyoutSubItem Text="Find">
                <MenuFlyoutItem Text="Find…" />
                <MenuFlyoutItem Text="Find Next" />
                <MenuFlyoutItem Text="Find Previous" />
              </MenuFlyoutSubItem>
            </MenuBarItem>
            <MenuBarItem Style="{StaticResource LiquidGlassMenuBarItemStyle}" Title="View">
              <MenuFlyoutItem Text="Zoom In" />
              <MenuFlyoutItem Text="Zoom Out" />
              <MenuFlyoutItem Text="Actual Size" />
              <MenuFlyoutSeparator />
              <MenuFlyoutSubItem Text="Appearance">
                <MenuFlyoutItem Text="Light" />
                <MenuFlyoutItem Text="Dark" />
                <MenuFlyoutItem Text="Automatic" />
              </MenuFlyoutSubItem>
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="Enter Full Screen" />
            </MenuBarItem>
          </MenuBar>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="CommandBar" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="A floating glass toolbar. The pinned toggle keeps a persistent highlight; the ellipsis opens two secondary commands on the overlay surface."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,0,0,10" />
          <CommandBar DefaultLabelPosition="Right">
            <AppBarButton Style="{StaticResource LiquidGlassAppBarButtonStyle}" Label="Save">
              <AppBarButton.Icon>
                <SymbolIcon Symbol="Save" />
              </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Style="{StaticResource LiquidGlassAppBarButtonStyle}" Label="Share">
              <AppBarButton.Icon>
                <SymbolIcon Symbol="Share" />
              </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Style="{StaticResource LiquidGlassAppBarButtonStyle}" Label="Delete">
              <AppBarButton.Icon>
                <SymbolIcon Symbol="Delete" />
              </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator Style="{StaticResource LiquidGlassAppBarSeparatorStyle}" />
            <AppBarToggleButton Style="{StaticResource LiquidGlassAppBarToggleButtonStyle}" Label="Pin" IsChecked="True">
              <AppBarToggleButton.Icon>
                <SymbolIcon Symbol="Pin" />
              </AppBarToggleButton.Icon>
            </AppBarToggleButton>
            <CommandBar.SecondaryCommands>
              <AppBarButton Style="{StaticResource LiquidGlassAppBarButtonStyle}" Label="Settings">
                <AppBarButton.Icon>
                  <SymbolIcon Symbol="Setting" />
                </AppBarButton.Icon>
              </AppBarButton>
              <AppBarButton Style="{StaticResource LiquidGlassAppBarButtonStyle}" Label="Help">
                <AppBarButton.Icon>
                  <SymbolIcon Symbol="Help" />
                </AppBarButton.Icon>
              </AppBarButton>
            </CommandBar.SecondaryCommands>
          </CommandBar>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="DropDownButton, SplitButton and ToggleSplitButton" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Glass capsules: the drop-down opens a menu, the split button pairs a default action with a chevron menu, and the toggle variant latches on with the prominent tint."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,0,0,10" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <DropDownButton Content="Export">
              <DropDownButton.Flyout>
                <MenuFlyout>
                  <MenuFlyoutItem Text="Export as PDF" />
                  <MenuFlyoutItem Text="Export as PNG" />
                  <MenuFlyoutSeparator />
                  <MenuFlyoutItem Text="Export All…" />
                </MenuFlyout>
              </DropDownButton.Flyout>
            </DropDownButton>
            <SplitButton x:Name="NewItemSplitButton" Content="New Note" Click="OnSplitButtonClick">
              <SplitButton.Flyout>
                <MenuFlyout Placement="Bottom">
                  <MenuFlyoutItem Text="New Note" Click="OnNewNote" />
                  <MenuFlyoutItem Text="New Folder" Click="OnNewFolder" />
                  <MenuFlyoutItem Text="New Tag" Click="OnNewTag" />
                </MenuFlyout>
              </SplitButton.Flyout>
            </SplitButton>
            <ToggleSplitButton Content="Bulleted List">
              <ToggleSplitButton.Flyout>
                <MenuFlyout Placement="Bottom">
                  <MenuFlyoutItem Text="Bulleted List" />
                  <MenuFlyoutItem Text="Numbered List" />
                  <MenuFlyoutItem Text="Checklist" />
                </MenuFlyout>
              </ToggleSplitButton.Flyout>
            </ToggleSplitButton>
          </StackPanel>
          <TextBlock x:Name="SplitStatus"
                     Text="Click the split button's primary side, or pick a type from its menu."
                     FontSize="13"
                     Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                     Margin="0,10,0,0" />
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</Page>
