<Page x:Class="LiquidGlassGallery.Pages.WindowsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer Padding="28,0">
    <StackPanel Spacing="16" HorizontalAlignment="Stretch" Padding="0,24,0,32">

      <TextBlock Text="Menus &amp; windows" FontSize="30" FontWeight="Bold" Foreground="White" />

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="MenuBar" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Menu popups float on the glass surface; rows highlight with the tint like macOS menus."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,0,0,10" />
          <MenuBar>
            <MenuBarItem Title="File">
              <MenuFlyoutItem Text="New" />
              <MenuFlyoutItem Text="Open…" />
              <MenuFlyoutItem Text="Save" />
              <MenuFlyoutSeparator />
              <MenuFlyoutItem Text="Close" />
            </MenuBarItem>
            <MenuBarItem Title="Edit">
              <MenuFlyoutItem Text="Cut" />
              <MenuFlyoutItem Text="Copy" />
              <MenuFlyoutItem Text="Paste" />
            </MenuBarItem>
            <MenuBarItem Title="View">
              <MenuFlyoutItem Text="Zoom in" />
              <MenuFlyoutItem Text="Zoom out" />
            </MenuBarItem>
          </MenuBar>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="TabView" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Tabs read as an Apple segmented control — the selected tab is a glass pill."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,0,0,10" />
          <TabView IsAddTabButtonVisible="False" TabWidthMode="SizeToContent" MaxHeight="180" VerticalAlignment="Top">
            <TabViewItem Header="Overview" IsClosable="False">
              <TextBlock Text="Overview content." FontSize="14" Margin="4,12"
                         Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
            </TabViewItem>
            <TabViewItem Header="Details" IsClosable="False">
              <TextBlock Text="Details content." FontSize="14" Margin="4,12"
                         Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
            </TabViewItem>
            <TabViewItem Header="Notes">
              <TextBlock Text="A closable tab." FontSize="14" Margin="4,12"
                         Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
            </TabViewItem>
          </TabView>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="MenuFlyout and ContentDialog" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
            <Button x:Name="MenuButton" Content="Open menu">
              <Button.Flyout>
                <MenuFlyout>
                  <MenuFlyoutItem Text="Duplicate" />
                  <MenuFlyoutItem Text="Rename…" />
                  <MenuFlyoutItem Text="Get info" />
                  <MenuFlyoutSeparator />
                  <MenuFlyoutItem Text="Move to Trash" />
                </MenuFlyout>
              </Button.Flyout>
            </Button>
            <Button Content="Show dialog" Click="OnShowDialog" />
            <Button x:Name="TeachingTipButton" Content="Show teaching tip" Click="OnShowTeachingTip">
              <Button.Resources>
                <TeachingTip x:Name="GlassTeachingTip"
                             Title="Liquid Glass tip"
                             Subtitle="Teaching tips now use the same frosted surface and capsule actions as dialogs."
                             Target="{Binding ElementName=TeachingTipButton}"
                             ActionButtonContent="Got it"
                             CloseButtonContent="Later"
                             PreferredPlacement="Top" />
              </Button.Resources>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</Page>
