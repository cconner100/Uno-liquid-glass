<Page x:Class="LiquidGlassGallery.Pages.StatusPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer Padding="28,0">
    <StackPanel Spacing="16" HorizontalAlignment="Stretch" Padding="0,24,0,32">

      <TextBlock Text="Pickers &amp; status" FontSize="30" FontWeight="Bold" Foreground="White" />

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="Progress" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <StackPanel Spacing="14" Margin="0,10,0,0">
            <ProgressBar Value="65" Maximum="100" />
            <ProgressBar IsIndeterminate="True" />
            <StackPanel Orientation="Horizontal" Spacing="12">
              <ProgressRing IsActive="True" Width="28" Height="28" />
              <TextBlock Text="ProgressRing" FontSize="14" VerticalAlignment="Center"
                         Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="Date and time pickers" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <StackPanel Spacing="10" Margin="0,8,0,0">
            <DatePicker Header="Date" />
            <TimePicker Header="Time" />
            <CalendarDatePicker Header="Calendar date" PlaceholderText="Pick a date" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="Overlays" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Flyouts and dialogs use the heavier glass surface material."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,0,0,10" />
          <StackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="Show flyout">
              <Button.Flyout>
                <Flyout>
                  <StackPanel Spacing="8" MinWidth="220">
                    <TextBlock Text="Glass flyout" FontWeight="SemiBold" />
                    <TextBlock Text="Floating above the content layer." FontSize="13"
                               Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
                  </StackPanel>
                </Flyout>
              </Button.Flyout>
            </Button>
            <Button Content="Show dialog" Click="OnShowDialog" />
          </StackPanel>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</Page>
