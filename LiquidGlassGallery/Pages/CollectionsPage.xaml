<Page x:Class="LiquidGlassGallery.Pages.CollectionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <ScrollViewer Padding="28,0">
    <StackPanel Spacing="16" MaxWidth="780" HorizontalAlignment="Stretch" Padding="0,24,0,32">

      <TextBlock Text="Collections" FontSize="30" FontWeight="Bold" Foreground="White" />

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="ComboBox" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <ComboBox Header="Appearance" SelectedIndex="0" MinWidth="220" Margin="0,8,0,0">
            <ComboBoxItem Content="Automatic" />
            <ComboBoxItem Content="Light" />
            <ComboBoxItem Content="Dark" />
          </ComboBox>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="ListView" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <ListView SelectionMode="Single" SelectedIndex="1" MaxHeight="260" Margin="0,8,0,0">
            <ListViewItem Content="Finder" />
            <ListViewItem Content="Safari" />
            <ListViewItem Content="Messages" />
            <ListViewItem Content="Music" />
            <ListViewItem Content="Photos" />
          </ListView>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="ListBox" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <TextBlock Text="Selection uses the same translucent Apple-tint band as ListView."
                     FontSize="13" TextWrapping="Wrap" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" />
          <ListBox SelectedIndex="1" Background="Transparent" BorderThickness="0" Margin="0,8,0,0">
            <ListBoxItem Content="Aluminum" />
            <ListBoxItem Content="Glass" />
            <ListBoxItem Content="Titanium" />
            <ListBoxItem Content="Ceramic" />
          </ListBox>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="GridView" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <GridView SelectionMode="Single" SelectedIndex="0" MaxHeight="220" Margin="0,8,0,0">
            <GridViewItem>
              <Border Width="72" Height="72" CornerRadius="16" Background="#FF5E5CE6" />
            </GridViewItem>
            <GridViewItem>
              <Border Width="72" Height="72" CornerRadius="16" Background="#FF007AFF" />
            </GridViewItem>
            <GridViewItem>
              <Border Width="72" Height="72" CornerRadius="16" Background="#FF34C759" />
            </GridViewItem>
            <GridViewItem>
              <Border Width="72" Height="72" CornerRadius="16" Background="#FFFF9F0A" />
            </GridViewItem>
            <GridViewItem>
              <Border Width="72" Height="72" CornerRadius="16" Background="#FFFF375F" />
            </GridViewItem>
            <GridViewItem>
              <Border Width="72" Height="72" CornerRadius="16" Background="#FFBF5AF2" />
            </GridViewItem>
          </GridView>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource LiquidGlassCardBorderStyle}">
        <StackPanel Spacing="4">
          <TextBlock Text="Pivot" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource LiquidGlassLabelBrush}" />
          <Pivot MaxHeight="180" Margin="0,4,0,0">
            <PivotItem Header="Recents">
              <TextBlock Text="Recently used items appear here." FontSize="14" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,8" />
            </PivotItem>
            <PivotItem Header="Shared">
              <TextBlock Text="Shared items appear here." FontSize="14" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,8" />
            </PivotItem>
            <PivotItem Header="Deleted">
              <TextBlock Text="Deleted items appear here." FontSize="14" Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}" Margin="0,8" />
            </PivotItem>
          </Pivot>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</Page>
