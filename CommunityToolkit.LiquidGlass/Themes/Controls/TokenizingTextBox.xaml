<!--
  LiquidGlass.CommunityToolkit — TokenizingTextBox.xaml
  Liquid Glass styling for CommunityToolkit.WinUI.Controls.TokenizingTextBox.

  Token chips as glass: translucent white chips (regular glass fallback colors) at rest,
  Apple tint with white text when selected. The text-entry part of the control already
  picks up the theme's TextControl* overrides (glass control fill).
  Key names come from TokenizingTextBoxItem.Token.xaml (TokenItem*). The toolkit
  hard-codes its token radius, so the token container is retemplated below while
  preserving the part names and state names used by the control implementation.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

  <ResourceDictionary.ThemeDictionaries>

    <!-- ================================ LIGHT ================================ -->
    <ResourceDictionary x:Key="Light">

      <!-- Chip background: regular glass (fallback colors of LiquidGlassFillBrush) -->
      <SolidColorBrush x:Key="TokenItemBackground" Color="#B8FFFFFF" />
      <SolidColorBrush x:Key="TokenItemBackgroundPointerOver" Color="#CCFFFFFF" />
      <SolidColorBrush x:Key="TokenItemBackgroundPressed" Color="#D9E5E5EA" />

      <!-- Selected chip: Apple tint -->
      <SolidColorBrush x:Key="TokenItemBackgroundSelected" Color="#007AFF" />
      <SolidColorBrush x:Key="TokenItemBackgroundPointerOverSelected" Color="#3395FF" />
      <SolidColorBrush x:Key="TokenItemBackgroundPressedSelected" Color="#0066D6" />

      <!-- Chip border: hairline at rest, none when tinted -->
      <SolidColorBrush x:Key="TokenItemBorderBrush" Color="#1F000000" />
      <SolidColorBrush x:Key="TokenItemBorderBrushPointerOver" Color="#29000000" />
      <SolidColorBrush x:Key="TokenItemBorderBrushPressed" Color="#29000000" />
      <SolidColorBrush x:Key="TokenItemBorderBrushSelected" Color="Transparent" />
      <SolidColorBrush x:Key="TokenItemBorderBrushPointerOverSelected" Color="Transparent" />
      <SolidColorBrush x:Key="TokenItemBorderBrushPressedSelected" Color="Transparent" />

      <!-- Chip foreground: label on glass, white on tint -->
      <SolidColorBrush x:Key="TokenItemForeground" Color="#000000" />
      <SolidColorBrush x:Key="TokenItemForegroundPointerOver" Color="#000000" />
      <SolidColorBrush x:Key="TokenItemForegroundPressed" Color="#993C3C43" />
      <SolidColorBrush x:Key="TokenItemForegroundSelected" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TokenItemForegroundPointerOverSelected" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TokenItemForegroundPressedSelected" Color="#CCFFFFFF" />

      <SolidColorBrush x:Key="TokenItemRemoveButtonBackgroundPointerOver" Color="#14000000" />
      <SolidColorBrush x:Key="TokenItemRemoveButtonBackgroundPressed" Color="#24000000" />

      <Thickness x:Key="TokenItemBorderThickness">1</Thickness>
    </ResourceDictionary>

    <!-- ================================ DARK ================================ -->
    <ResourceDictionary x:Key="Default">

      <SolidColorBrush x:Key="TokenItemBackground" Color="#A63A3A3C" />
      <SolidColorBrush x:Key="TokenItemBackgroundPointerOver" Color="#BF48484A" />
      <SolidColorBrush x:Key="TokenItemBackgroundPressed" Color="#CC2C2C2E" />

      <SolidColorBrush x:Key="TokenItemBackgroundSelected" Color="#0A84FF" />
      <SolidColorBrush x:Key="TokenItemBackgroundPointerOverSelected" Color="#409CFF" />
      <SolidColorBrush x:Key="TokenItemBackgroundPressedSelected" Color="#086CD9" />

      <SolidColorBrush x:Key="TokenItemBorderBrush" Color="#26FFFFFF" />
      <SolidColorBrush x:Key="TokenItemBorderBrushPointerOver" Color="#40FFFFFF" />
      <SolidColorBrush x:Key="TokenItemBorderBrushPressed" Color="#40FFFFFF" />
      <SolidColorBrush x:Key="TokenItemBorderBrushSelected" Color="Transparent" />
      <SolidColorBrush x:Key="TokenItemBorderBrushPointerOverSelected" Color="Transparent" />
      <SolidColorBrush x:Key="TokenItemBorderBrushPressedSelected" Color="Transparent" />

      <SolidColorBrush x:Key="TokenItemForeground" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TokenItemForegroundPointerOver" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TokenItemForegroundPressed" Color="#99EBEBF5" />
      <SolidColorBrush x:Key="TokenItemForegroundSelected" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TokenItemForegroundPointerOverSelected" Color="#FFFFFF" />
      <SolidColorBrush x:Key="TokenItemForegroundPressedSelected" Color="#CCFFFFFF" />

      <SolidColorBrush x:Key="TokenItemRemoveButtonBackgroundPointerOver" Color="#26FFFFFF" />
      <SolidColorBrush x:Key="TokenItemRemoveButtonBackgroundPressed" Color="#3DFFFFFF" />

      <Thickness x:Key="TokenItemBorderThickness">1</Thickness>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!-- A 32px chip with a 16px outer radius forms an iOS-style capsule. The 10px
       remove button radius remains concentric inside it. -->
  <Thickness x:Key="TokenItemPadding">12,5,6,5</Thickness>
  <x:Double x:Key="LiquidGlassTokenMinHeight">32</x:Double>
  <CornerRadius x:Key="LiquidGlassTokenCornerRadius">16</CornerRadius>

  <Style x:Key="LiquidGlassTokenRemoveButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="2" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid>
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="ButtonBackground.Background" Value="{ThemeResource TokenItemRemoveButtonBackgroundPointerOver}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="ButtonBackground.Background" Value="{ThemeResource TokenItemRemoveButtonBackgroundPressed}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="ButtonBackground.Opacity" Value="0.45" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Border x:Name="ButtonBackground"
                    Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}">
              <ContentPresenter Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                Foreground="{TemplateBinding Foreground}" />
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="LiquidGlassTokenizingTextBoxItemStyle"
         TargetType="controls:TokenizingTextBoxItem">
    <Setter Property="ClearButtonStyle" Value="{StaticResource LiquidGlassTokenRemoveButtonStyle}" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="MinHeight" Value="{StaticResource LiquidGlassTokenMinHeight}" />
    <Setter Property="Background" Value="{ThemeResource TokenItemBackground}" />
    <Setter Property="BorderBrush" Value="{ThemeResource TokenItemBorderBrush}" />
    <Setter Property="BorderThickness" Value="{ThemeResource TokenItemBorderThickness}" />
    <Setter Property="CornerRadius" Value="{StaticResource LiquidGlassTokenCornerRadius}" />
    <Setter Property="Padding" Value="{StaticResource TokenItemPadding}" />
    <Setter Property="Foreground" Value="{ThemeResource TokenItemForeground}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="IsTabStop" Value="True" />
    <Setter Property="TabNavigation" Value="Local" />
    <Setter Property="UseSystemFocusVisuals" Value="True" />
    <Setter Property="FocusVisualMargin" Value="-2" />
    <Setter Property="BackgroundSizing" Value="InnerBorderEdge" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:TokenizingTextBoxItem">
          <Grid x:Name="PART_RootGrid"
                MinHeight="{TemplateBinding MinHeight}"
                Padding="{TemplateBinding Padding}"
                HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                VerticalAlignment="{TemplateBinding VerticalAlignment}"
                Background="{TemplateBinding Background}"
                BackgroundSizing="{TemplateBinding BackgroundSizing}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                ColumnSpacing="6"
                Control.IsTemplateFocusTarget="True"
                CornerRadius="{TemplateBinding CornerRadius}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="PART_RootGrid.Background" Value="{ThemeResource TokenItemBackgroundPointerOver}" />
                    <Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource TokenItemBorderBrushPointerOver}" />
                    <Setter Target="PART_ContentPresenter.Foreground" Value="{ThemeResource TokenItemForegroundPointerOver}" />
                    <Setter Target="PART_RemoveButton.Foreground" Value="{ThemeResource TokenItemForegroundPointerOver}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="PART_RootGrid.Background" Value="{ThemeResource TokenItemBackgroundPressed}" />
                    <Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource TokenItemBorderBrushPressed}" />
                    <Setter Target="PART_ContentPresenter.Foreground" Value="{ThemeResource TokenItemForegroundPressed}" />
                    <Setter Target="PART_RemoveButton.Foreground" Value="{ThemeResource TokenItemForegroundPressed}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Selected">
                  <VisualState.Setters>
                    <Setter Target="PART_RootGrid.Background" Value="{ThemeResource TokenItemBackgroundSelected}" />
                    <Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource TokenItemBorderBrushSelected}" />
                    <Setter Target="PART_ContentPresenter.Foreground" Value="{ThemeResource TokenItemForegroundSelected}" />
                    <Setter Target="PART_RemoveButton.Foreground" Value="{ThemeResource TokenItemForegroundSelected}" />
                    <Setter Target="PART_RootGrid.BackgroundSizing" Value="OuterBorderEdge" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="PointerOverSelected">
                  <VisualState.Setters>
                    <Setter Target="PART_RootGrid.Background" Value="{ThemeResource TokenItemBackgroundPointerOverSelected}" />
                    <Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource TokenItemBorderBrushPointerOverSelected}" />
                    <Setter Target="PART_ContentPresenter.Foreground" Value="{ThemeResource TokenItemForegroundPointerOverSelected}" />
                    <Setter Target="PART_RemoveButton.Foreground" Value="{ThemeResource TokenItemForegroundPointerOverSelected}" />
                    <Setter Target="PART_RootGrid.BackgroundSizing" Value="OuterBorderEdge" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="PressedSelected">
                  <VisualState.Setters>
                    <Setter Target="PART_RootGrid.Background" Value="{ThemeResource TokenItemBackgroundPressedSelected}" />
                    <Setter Target="PART_RootGrid.BorderBrush" Value="{ThemeResource TokenItemBorderBrushPressedSelected}" />
                    <Setter Target="PART_ContentPresenter.Foreground" Value="{ThemeResource TokenItemForegroundPressedSelected}" />
                    <Setter Target="PART_RemoveButton.Foreground" Value="{ThemeResource TokenItemForegroundPressedSelected}" />
                    <Setter Target="PART_RootGrid.BackgroundSizing" Value="OuterBorderEdge" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="DisabledStates">
                <VisualState x:Name="Enabled" />
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="PART_RootGrid.Opacity" Value="0.45" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <ContentPresenter x:Name="PART_ContentPresenter"
                              Grid.Column="0"
                              VerticalAlignment="Center"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                              Content="{TemplateBinding Content}"
                              ContentTransitions="{TemplateBinding ContentTransitions}"
                              FontWeight="{TemplateBinding FontWeight}"
                              Foreground="{TemplateBinding Foreground}" />
            <Button x:Name="PART_RemoveButton"
                    Grid.Column="1"
                    Width="20"
                    Height="20"
                    MinWidth="0"
                    MinHeight="0"
                    Padding="2"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="10"
                    IsTabStop="False"
                    Style="{TemplateBinding ClearButtonStyle}">
              <FontIcon FontSize="11" Glyph="&#xE894;" />
            </Button>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <controls:TokenizingTextBoxStyleSelector x:Key="LiquidGlassTokenizingTextBoxStyleSelector"
                                           TextStyle="{StaticResource TokenizingTextBoxItemTextStyle}"
                                           TokenStyle="{StaticResource LiquidGlassTokenizingTextBoxItemStyle}" />

  <Style x:Key="LiquidGlassTokenizingTextBoxStyle"
         TargetType="controls:TokenizingTextBox"
         BasedOn="{StaticResource DefaultTokenizingTextBoxStyle}">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassControlFillBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="6" />
    <Setter Property="TokenSpacing" Value="6" />
    <Setter Property="ItemContainerStyleSelector" Value="{StaticResource LiquidGlassTokenizingTextBoxStyleSelector}" />
  </Style>

  <Style TargetType="controls:TokenizingTextBox"
         BasedOn="{StaticResource LiquidGlassTokenizingTextBoxStyle}" />
</ResourceDictionary>
