<!-- SettingsCard / SettingsExpander / SettingsGroup: DevWinUI-style settings rows on Liquid Glass. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:DevWinUI.LiquidGlass">

  <Style TargetType="local:SettingsCard" BasedOn="{StaticResource LiquidGlassSettingsCardStyle}" />
  <Style TargetType="local:SettingsExpander" BasedOn="{StaticResource LiquidGlassSettingsExpanderStyle}" />
  <Style TargetType="local:SettingsGroup" BasedOn="{StaticResource LiquidGlassSettingsGroupStyle}" />

  <!-- ============================ SettingsCard ============================ -->
  <Style x:Key="LiquidGlassSettingsCardStyle" TargetType="local:SettingsCard">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassFillBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="MinHeight" Value="56" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="HorizontalContentAlignment" Value="Right" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="UseSystemFocusVisuals" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="local:SettingsCard">
          <Grid x:Name="RootGrid" MinHeight="{TemplateBinding MinHeight}">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <VisualState.Setters>
                    <Setter Target="HoverOverlay.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <VisualState.Setters>
                    <Setter Target="PressOverlay.Opacity" Value="1" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="RootGrid.Opacity" Value="0.45" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <!-- Glass material -->
            <Border x:Name="GlassFill"
                    Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}" />
            <!-- Interaction overlays -->
            <Border x:Name="HoverOverlay"
                    Background="{ThemeResource LiquidGlassHoverOverlayBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <Border x:Name="PressOverlay"
                    Background="{ThemeResource LiquidGlassPressedOverlayBrush}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0"
                    IsHitTestVisible="False" />
            <!-- Rim light -->
            <Border x:Name="Rim"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    IsHitTestVisible="False" />

            <Grid Padding="{TemplateBinding Padding}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Viewbox x:Name="PART_HeaderIconPresenterHolder"
                       Width="20"
                       Height="20"
                       Margin="2,0,14,0"
                       VerticalAlignment="Center"
                       Visibility="Collapsed">
                <ContentPresenter Content="{TemplateBinding HeaderIcon}"
                                  Foreground="{TemplateBinding Foreground}" />
              </Viewbox>

              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <ContentPresenter x:Name="PART_HeaderPresenter"
                                  Content="{TemplateBinding Header}"
                                  Foreground="{TemplateBinding Foreground}"
                                  TextWrapping="Wrap" />
                <ContentPresenter x:Name="PART_DescriptionPresenter"
                                  Margin="0,2,0,0"
                                  Content="{TemplateBinding Description}"
                                  FontSize="13"
                                  Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                                  TextWrapping="Wrap" />
              </StackPanel>

              <ContentPresenter Grid.Column="2"
                                Margin="16,0,0,0"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTransitions="{TemplateBinding ContentTransitions}" />

              <Viewbox x:Name="PART_ActionIconPresenterHolder"
                       Grid.Column="3"
                       Width="12"
                       Height="12"
                       Margin="14,0,2,0"
                       VerticalAlignment="Center"
                       Visibility="Collapsed">
                <ContentPresenter Content="{TemplateBinding ActionIcon}"
                                  Foreground="{ThemeResource LiquidGlassTertiaryLabelBrush}" />
              </Viewbox>
            </Grid>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Rows hosted inside a SettingsExpander: flat clear glass with a hairline above each row. -->
  <Style x:Key="LiquidGlassSettingsExpanderItemStyle"
         TargetType="local:SettingsCard"
         BasedOn="{StaticResource LiquidGlassSettingsCardStyle}">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassSeparatorBrush}" />
    <Setter Property="BorderThickness" Value="0,1,0,0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="MinHeight" Value="48" />
    <Setter Property="Padding" Value="16,10" />
  </Style>

  <!-- ============================ SettingsExpander ============================ -->
  <Style x:Key="LiquidGlassSettingsExpanderStyle" TargetType="local:SettingsExpander">
    <Setter Property="Background" Value="{ThemeResource LiquidGlassFillBrush}" />
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource LiquidGlassStrokeBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="MinHeight" Value="56" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="local:SettingsExpander">
          <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Glass material behind header + items -->
            <Border x:Name="GlassFill"
                    Grid.RowSpan="2"
                    Background="{TemplateBinding Background}"
                    CornerRadius="{TemplateBinding CornerRadius}" />

            <!-- Header row: a transparent SettingsCard supplies layout + hover/pressed states + chevron -->
            <local:SettingsCard x:Name="PART_HeaderCard"
                                MinHeight="{TemplateBinding MinHeight}"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Content="{TemplateBinding Content}"
                                Description="{TemplateBinding Description}"
                                Header="{TemplateBinding Header}"
                                HeaderIcon="{TemplateBinding HeaderIcon}"
                                IsClickEnabled="True" />

            <!-- Expandable items area: clear glass, hairline-separated rows -->
            <Border x:Name="PART_ItemsContainer"
                    Grid.Row="1"
                    Background="{ThemeResource LiquidGlassClearFillBrush}"
                    CornerRadius="0,0,15,15"
                    Visibility="Collapsed">
              <StackPanel>
                <ContentPresenter Content="{TemplateBinding ItemsHeader}" />
                <ItemsControl x:Name="PART_ItemsControl" IsTabStop="False">
                  <ItemsControl.Resources>
                    <Style TargetType="local:SettingsCard" BasedOn="{StaticResource LiquidGlassSettingsExpanderItemStyle}" />
                  </ItemsControl.Resources>
                </ItemsControl>
                <ContentPresenter Content="{TemplateBinding ItemsFooter}" />
              </StackPanel>
            </Border>

            <!-- Rim light drawn above everything -->
            <Border x:Name="Rim"
                    Grid.RowSpan="2"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    IsHitTestVisible="False" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ============================ SettingsGroup ============================ -->
  <Style x:Key="LiquidGlassSettingsGroupStyle" TargetType="local:SettingsGroup">
    <Setter Property="Foreground" Value="{ThemeResource LiquidGlassLabelBrush}" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="local:SettingsGroup">
          <StackPanel>
            <ContentPresenter x:Name="PART_HeaderPresenter"
                              Margin="2,0,2,0"
                              Content="{TemplateBinding Header}"
                              FontSize="17"
                              FontWeight="SemiBold"
                              Foreground="{TemplateBinding Foreground}"
                              TextWrapping="Wrap"
                              Visibility="Collapsed" />
            <ContentPresenter x:Name="PART_DescriptionPresenter"
                              Margin="2,4,2,0"
                              Content="{TemplateBinding Description}"
                              FontSize="13"
                              Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                              TextWrapping="Wrap"
                              Visibility="Collapsed" />
            <ItemsControl x:Name="PART_ItemsControl"
                          Margin="0,10,0,0"
                          IsTabStop="False">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
