<!-- GrowlItem: toast notification card on the heavy glass surface material. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:DevWinUI.LiquidGlass">

  <Style TargetType="local:GrowlItem" BasedOn="{StaticResource LiquidGlassGrowlItemStyle}" />

  <Style x:Key="LiquidGlassGrowlItemStyle" TargetType="local:GrowlItem">
    <Setter Property="Width" Value="340" />
    <Setter Property="HorizontalAlignment" Value="Right" />
    <Setter Property="Margin" Value="0,0,0,8" />
    <Setter Property="SuccessBrush" Value="{ThemeResource LiquidGlassSuccessBrush}" />
    <Setter Property="InfoBrush" Value="{ThemeResource LiquidGlassTintBrush}" />
    <Setter Property="WarningBrush" Value="#FF9F0A" />
    <Setter Property="ErrorBrush" Value="{ThemeResource LiquidGlassDestructiveBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="local:GrowlItem">
          <Grid Padding="14,12,10,12"
                Background="{ThemeResource LiquidGlassSurfaceBrush}"
                BorderBrush="{ThemeResource LiquidGlassStrokeBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <FontIcon x:Name="PART_Icon"
                      Margin="0,2,10,0"
                      VerticalAlignment="Top"
                      FontSize="16"
                      Glyph="&#xE946;" />

            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
              <TextBlock x:Name="PART_Title"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource LiquidGlassLabelBrush}"
                         Text="{TemplateBinding Title}"
                         TextWrapping="Wrap" />
              <TextBlock FontSize="13"
                         Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                         Text="{TemplateBinding Message}"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Button x:Name="PART_CloseButton"
                    Grid.Column="2"
                    Width="24"
                    Height="24"
                    MinWidth="0"
                    MinHeight="0"
                    Margin="6,0,0,0"
                    Padding="0"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="12">
              <FontIcon FontSize="10"
                        Foreground="{ThemeResource LiquidGlassSecondaryLabelBrush}"
                        Glyph="&#xE711;" />
            </Button>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
